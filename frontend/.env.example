# GenLayer network to target: bradbury | asimov | studionet | localnet
NEXT_PUBLIC_GENLAYER_CHAIN=bradbury

# GenLayer RPC endpoint (defaults to Bradbury testnet)
NEXT_PUBLIC_GENLAYER_RPC_URL=https://rpc-bradbury.genlayer.com
NEXT_PUBLIC_GENLAYER_CHAIN_ID=4221
NEXT_PUBLIC_GENLAYER_CHAIN_NAME=GenLayer Testnet Bradbury
NEXT_PUBLIC_GENLAYER_SYMBOL=GEN

# Address of your deployed DebateArena contract (from `npm run deploy`)
NEXT_PUBLIC_CONTRACT_ADDRESS=your_contract_address
